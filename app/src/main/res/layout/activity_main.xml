<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    tools:context=".MainActivity">

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/selectAudioDeviceButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="选择 ALSA card" />

        <Button
            android:id="@+id/playButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="同时播放" />

        <Button
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="停止播放" />

        <Button
            android:id="@+id/playPcmButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="🎵 PCM 测试 (合成 440Hz 正弦波，模拟 Unity 路径)" />

        <Button
            android:id="@+id/playMixerConcurrentButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="🎚 Mixer 并发 (软件混音 26/27/28.mp3 + sine)" />

        <Button
            android:id="@+id/stopMixerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛑 停止 Mixer" />
    </LinearLayout>

    <TextView
        android:id="@+id/audioDeviceListTextView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:text="正在读取音频输出设备..."
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/controlPanel" />

</androidx.constraintlayout.widget.ConstraintLayout>
